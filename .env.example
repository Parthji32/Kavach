# Kavach Configuration
# Copy this to .env and fill in your values

# Server
PORT=8080

# Database (optional - runs in demo mode without it)
# DATABASE_URL=postgres://user:pass@localhost:5432/kavach?sslmode=disable
# Or use individual vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_CRED=your_credential_here
# DB_NAME=kavach
# DB_SSLMODE=disable

# JWT signing key (auto-generated in dev if empty)
JWT_SECRET=change-this-in-production-use-a-long-random-string

# Geo Enrichment (optional - uses mock data without it)
IPINFO_TOKEN=your_ipinfo_token

# Email Alerts via Resend (optional)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_TO_EMAIL=security@yourcompany.com

# Slack Alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxxx

# Base URL for token trigger links
BASE_URL=http://localhost:8080
